# ===========================================
# Acadion Environment Variables Template
# ===========================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control!

# ===========================================
# SUPABASE (Required)
# ===========================================
# Get these from your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ===========================================
# APP CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ===========================================
# AUTHENTICATION
# ===========================================
# Supabase Auth configuration (optional)
NEXT_PUBLIC_SUPABASE_AUTH_TIMEOUT=60000
NEXT_DEFAULT_SESSION_TIMEOUT=604800

# ===========================================
# FIREBASE CLOUD MESSAGING (Optional)
# ===========================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ===========================================
# PAYMENT GATEWAYS (Optional)
# ===========================================
# Paystack
PAYSTACK_SECRET_KEY=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# ===========================================
# CRM INTEGRATION (Optional)
# ===========================================
HUBSPOT_API_KEY=
SALESFORCE_INSTANCE_URL=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
ZENDESK_SUBDOMAIN=
ZENDESK_API_TOKEN=

# ===========================================
# EMAIL (Optional)
# ===========================================
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# ===========================================
# ANALYTICS (Optional)
# ===========================================
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=

# ===========================================
# OPENCODE ZEN - BIG PICKLE AI (Optional)
# ===========================================
# Free AI model for transcription, summarization, and quiz generation
# Get your API key from https://opencode.ai/zen
OPENCODE_API_KEY=

# ===========================================
# VERCEL (Do not modify)
# ===========================================
VERCEL_URL=
VERCEL_GIT_COMMIT_SHA=
